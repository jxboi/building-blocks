# Building Blocks — environment configuration.
# Copy to .env for local development. Keep this file exhaustive: CI checks for
# drift (docker-deployment plan). Secrets live here / in the environment only —
# never in the settings registry.

# --- PostgreSQL (infra/docker-compose.yml) -----------------------------------
POSTGRES_DB=building_blocks
POSTGRES_USER=bb
POSTGRES_PASSWORD=bb_dev_password
POSTGRES_PORT=5432

# Connection string consumed by the API (Npgsql format).
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=building_blocks;Username=bb;Password=bb_dev_password

# Apply EF migrations on API startup. Dev convenience only — never enable in prod,
# where the Migrator runs migrations as a deploy step.
Database__MigrateOnStartup=true
